{
  "name": "happypause-mobile",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "docker-build": "cd .. && docker compose build",
    "docker-push": "cd .. && docker compose push",
    "build-web": "npx expo export -p web",
    "build-mobile-dev-android": "npx eas-cli build --profile development --platform android",
    "build-mobile-dev-ios": "npx eas-cli build --profile development --platform ios",
    "build-mobile-prod-android": "npx eas-cli build --profile production --platform android",
    "build-mobile-prod-ios": "npx eas-cli build --profile production --platform ios"
  },
  "dependencies": {
    "@expo-google-fonts/poppins": "^0.2.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-google-signin/google-signin": "^13.2.0",
    "@react-navigation/native": "^7.0.14",
    "expo": "~54.0.33",
    "expo-apple-authentication": "~8.0.8",
    "expo-av": "~16.0.8",
    "expo-constants": "~18.0.13",
    "expo-dev-client": "~6.0.20",
    "expo-file-system": "~19.0.21",
    "expo-font": "~14.0.11",
    "expo-image-picker": "~17.0.10",
    "expo-linking": "~8.0.11",
    "expo-router": "~6.0.23",
    "expo-secure-store": "~15.0.2",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "^0.21.2"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
